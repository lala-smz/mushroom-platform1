  gap: 10px;
}

/* 表格选中行样式 */
:deep(.el-table__body tr.is-selected &gt; td) {
  background-color: #e6f7ff !important;
}

:deep(.el-table__body tr.is-selected:hover &gt; td) {
  background-color: #d1edff !important;
}

.recipe-image {
  width: 40px;
  height: 40px;
  border-radius: 4px;
  object-fit: cover;
}

