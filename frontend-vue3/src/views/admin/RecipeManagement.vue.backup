  margin-bottom: 15px;
  padding: 12px;
  background: white;
  border-radius: 4px;
  border: 1px solid #e4e7ed;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.step-number {
  font-weight: bold;
  color: #409eff;
}

/* 口味和菜系选择样式 */
.flavor-select,
.cuisine-select {
  width: 300px;
}

.custom-input-container {
