  display: flex;
  gap: 10px;
  align-items: center;
}

.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20px;
  padding: 15px;
  background-color: #f5f7fa;
  border-radius: 8px;
  flex-wrap: wrap;
  gap: 15px;
}

.filter-form {
  display: flex;
  align-items: center;
  gap: 15px;
  flex-wrap: wrap;
}

.search-box {
  display: flex;
  align-items: center;
}

.left-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.right-actions {
  display: flex;
  gap: 10px;
}

.search-input {
  width: 300px;
}

.recipes-card {
