# ============================================
# 支付配置 - 支付宝和银行卡支付
# ============================================

# ------------------------------
# 支付宝配置
# ------------------------------
# 支付宝APPID（在支付宝开放平台获取）
ALIPAY_APP_ID=your_alipay_app_id

# 支付宝私钥（PKCS8格式）
ALIPAY_PRIVATE_KEY=your_alipay_private_key

# 支付宝公钥（从支付宝开放平台获取）
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# 支付宝网关（正式环境）
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 支付宝回调地址
ALIPAY_NOTIFY_URL=http://yourdomain.com/api/order/pay/alipay/notify

# 支付宝返回地址
ALIPAY_RETURN_URL=http://yourdomain.com/order/success

# ------------------------------
# 银联支付配置（银行卡支付）
# ------------------------------
# 银联商户号
UNIONPAY_MER_ID=your_unionpay_merchant_id

# 银联证书路径
UNIONPAY_CERT_PATH=/path/to/your/cert.pem

# 银联密钥路径
UNIONPAY_KEY_PATH=/path/to/your/key.pem

# 银联网关
UNIONPAY_GATEWAY=https://gateway.95516.com

# 银联回调地址
UNIONPAY_NOTIFY_URL=http://yourdomain.com/api/order/pay/unionpay/notify

# 银联返回地址
UNIONPAY_RETURN_URL=http://yourdomain.com/order/success

# ------------------------------
# 通用支付配置
# ------------------------------
# 支付超时时间（分钟）
PAYMENT_TIMEOUT=30

# 允许的支付方式
ALLOWED_PAYMENT_METHODS=alipay,wechat,bank

# 支付签名密钥（用于内部签名验证）
PAYMENT_SIGN_KEY=your_secure_payment_sign_key_here

# 支付日志级别
PAYMENT_LOG_LEVEL=info

# 是否启用支付验证
ENABLE_PAYMENT_VERIFICATION=true

# ------------------------------
# 数据库配置（已有配置，确保正确）
# ------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mushroom_db
DB_USER=root
DB_PASSWORD=your_password

# ------------------------------
# 服务器配置（已有配置，确保正确）
# ------------------------------
PORT=3303
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key